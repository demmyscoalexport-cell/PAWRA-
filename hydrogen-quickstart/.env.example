# PAWRA Hydrogen — environment variables
# Copy this file to .env in hydrogen-quickstart/ for local development.
# Never commit .env — it is gitignored.

# Required — random string for session encryption (generate a long random value for production)
SESSION_SECRET=""

# Shopify Storefront API (from Shopify Admin → Sales channels → Headless → your storefront)
PUBLIC_STOREFRONT_API_TOKEN=""
PUBLIC_STORE_DOMAIN="pawrapetshop.myshopify.com"
PUBLIC_STOREFRONT_ID="1000148769"
PRIVATE_STOREFRONT_API_TOKEN=""

# Checkout & customer accounts
PUBLIC_CHECKOUT_DOMAIN="pawrapetshop.myshopify.com"
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# Optional — set by `shopify hydrogen link` / Oxygen deploy (do not commit)
# PRIVATE_STOREFRONT_API_TOKEN=""
# SHOP_ID=""

# Optional — only needed if you add webhook routes (verify HMAC signatures)
# SHOPIFY_WEBHOOK_SECRET=""
