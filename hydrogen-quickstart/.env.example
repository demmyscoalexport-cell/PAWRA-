# PAWRA Hydrogen — environment variables
# Copy to .env in this folder. Never commit .env.
#
# After creating a NEW Shopify store:
#   cd hydrogen-quickstart
#   npx shopify hydrogen link
#   npx shopify hydrogen env pull

# ─── Session ────────────────────────────────────────────────────────────────
SESSION_SECRET=""

# ─── Shopify Storefront API (Hydrogen channel → your storefront → API) ───
PUBLIC_STOREFRONT_API_TOKEN=""
# Prefer your-store.myshopify.com from `hydrogen env pull` (API host)
PUBLIC_STORE_DOMAIN="pawra-pet-cares.myshopify.com"
PUBLIC_STOREFRONT_ID=""
# Private token — server-side only, never expose to the browser
PRIVATE_STOREFRONT_API_TOKEN=""

# ─── Checkout ───────────────────────────────────────────────────────────────
# Use checkout.pawrapetcares.com if connected in Settings → Domains (Target: Online Store)
PUBLIC_CHECKOUT_DOMAIN="checkout.pawrapetcares.com"

# ─── Customer Account API (/account login & orders) ─────────────────────────
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# ─── Webhooks (optional) ────────────────────────────────────────────────────
SHOPIFY_WEBHOOK_SECRET=""

# ─── Admin API (custom app — catalog setup scripts) ───────────────────────
SHOPIFY_ADMIN_API_TOKEN=""

# ─── Oxygen deploy (local CLI / GitHub Actions — never commit real value) ──
# Also set as GitHub secret: Settings → Secrets → Actions → SHOPIFY_HYDROGEN_DEPLOYMENT_TOKEN
SHOPIFY_HYDROGEN_DEPLOYMENT_TOKEN=""

# ─── Cloudinary ─────────────────────────────────────────────────────────────
PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_URL=""

# ─── WaveSpeed AI (optional hero video) ─────────────────────────────────────
WAVESPEED_API_KEY=""

# ─── Tier A apps ────────────────────────────────────────────────────────────
# Judge.me (Hydrogen headless)
# Settings → Integrations → View API tokens
# shop_domain must be the myshopify.com domain registered in Judge.me
# JUDGEME_API_TOKEN = private (server only); PUBLIC_JUDGEME_PUBLIC_TOKEN = public (widget script)
PUBLIC_JUDGEME_SHOP_DOMAIN=""
JUDGEME_API_TOKEN=""
PUBLIC_JUDGEME_PUBLIC_TOKEN=""
PUBLIC_KLAVIYO_COMPANY_ID=""
PUBLIC_GA4_MEASUREMENT_ID=""

# ─── Tier B apps ────────────────────────────────────────────────────────────
PUBLIC_SWYM_STORE_ID=""
PUBLIC_SWYM_WISHLIST_URL="/account/wishlist"
PUBLIC_SMILE_PUBLISHABLE_KEY=""
PUBLIC_SMILE_REWARDS_URL="/pages/rewards"
PUBLIC_RECHARGE_STORE_IDENTIFIER=""

# ─── Tier C apps ────────────────────────────────────────────────────────────
PUBLIC_GORGIAS_WIDGET_ID=""
PUBLIC_LOOP_RETURNS_URL=""

# Mirror ALL values above in Shopify Admin → Hydrogen → Environment variables.
# Run: npm run oxygen:env-checklist
