# PAWRA Hydrogen — environment variables
# Copy to .env in this folder before local dev. Never commit .env.

# ─── Session ────────────────────────────────────────────────────────────────
# Required — random string for session encryption (server-side only)
SESSION_SECRET=""

# ─── Shopify Storefront API (Admin → Sales channels → Headless) ─────────────
# Public token — safe for client-side use via Hydrogen storefront client
PUBLIC_STOREFRONT_API_TOKEN=""
PUBLIC_STORE_DOMAIN="pawrapetshop.myshopify.com"
PUBLIC_STOREFRONT_ID="1000148769"
# Private token — server-side only, never expose to the browser
PRIVATE_STOREFRONT_API_TOKEN=""

# ─── Checkout ───────────────────────────────────────────────────────────────
PUBLIC_CHECKOUT_DOMAIN="pawrapetshop.myshopify.com"

# ─── Customer Account API (optional — /account login & orders) ────────────
PUBLIC_CUSTOMER_ACCOUNT_API_CLIENT_ID=""
PUBLIC_CUSTOMER_ACCOUNT_API_URL=""

# ─── Webhooks (optional) ────────────────────────────────────────────────────
# Server-side HMAC verification secret — never expose
SHOPIFY_WEBHOOK_SECRET=""
