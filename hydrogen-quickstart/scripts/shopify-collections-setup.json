  "paymentSetup": {
    "note": "Payments are handled by Shopify Checkout — enable in Admin → Settings → Payments",
    "recommended": ["Shopify Payments", "PayPal", "Apple Pay", "Google Pay", "Shop Pay"],
    "checkoutDomain": "pawrapetshop.myshopify.com"
